{
  "manifest_version": 2,

  "name": "Town of Salem - Support Tool",
  "description": "This extension allows users to keep track of taken roles and player role claims.",
  "version": "0.1.1",
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },

  "browser_action": {
    "default_icon": {
      "19": "img/icon19.png",
      "38": "img/icon38.png",
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    },
    "default_popup": "html/support.html"
  },
  "short_name": "TOS Support",
  "author": "Aaron Beetstra",
  "permissions": [
    "activeTab",
    "storage"
  ]
}
